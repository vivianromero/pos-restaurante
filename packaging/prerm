#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure)

        echo "=== Deteniendo POS System ==="

        # detener servicio si está activo
        systemctl stop pos-system.service 2>/dev/null || true

        # deshabilitar servicio para evitar reinicios automáticos
        systemctl disable pos-system.service 2>/dev/null || true

        # recargar systemd para limpiar referencias
        systemctl daemon-reload || true

        ;;
esac

exit 0

